APP_ENV=dev

LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace_me
LLM_MODEL=deepseek-v4-pro

EMBEDDING_PROVIDER=deepseek
EMBEDDING_MODEL=deepseek-v4-pro
EMBEDDING_DIM=1536

MAX_CHUNK_CHARS=1500
CHUNK_OVERLAP_CHARS=200
MAX_RETRIEVED_CHUNKS=8

ENABLE_LIGHTRAG=false
ENABLE_AUTO_REVISION=true
MAX_AUTO_REVISION_ROUNDS=1

IMAGE_PROVIDER=glm
IMAGE_BASE_URL=https://open.bigmodel.cn/api/paas/v4/images/generations
IMAGE_API_KEY=
IMAGE_MODEL=cogview-4

TTS_PROVIDER=openai-compatible
TTS_BASE_URL=
TTS_API_KEY=
TTS_MODEL=

# Account storage and secure session cookies. In production, keep the database
# outside the release directory and serve the site over HTTPS.
AUTH_DB_PATH=/var/lib/novel2gal/auth.sqlite3
SESSION_COOKIE_SECURE=true

# One-time production bootstrap only. Remove the password and claim flag after
# the first successful start; the administrator remains in AUTH_DB_PATH.
NOVEL2GAL_ADMIN_USERNAME=
NOVEL2GAL_ADMIN_PASSWORD=
NOVEL2GAL_CLAIM_LEGACY_TO_ADMIN=false

# Required in production. Used to encrypt every user's BYOK API key at rest.
# Keep this value stable across restarts and deployments; changing it makes
# previously stored keys unreadable.
API_CONFIG_SECRET=replace_with_a_long_random_secret

# Custom API endpoints must use HTTPS and cannot resolve to private/local IPs
# by default. Enable only for a trusted self-hosted provider deployment.
ALLOW_INSECURE_API_URLS=false
ALLOW_PRIVATE_API_URLS=false

# Production persistence. Redis carries durable background jobs, PostgreSQL
# stores project JSON metadata, and S3-compatible storage stores generated media.
REDIS_URL=redis://127.0.0.1:6379/0
DATABASE_URL=postgresql://novel2gal:replace_me@127.0.0.1:5432/novel2gal
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=novel2gal
S3_SECRET_ACCESS_KEY=replace_me
S3_BUCKET=novel2gal-media
S3_REGION=us-east-1
